# ==============================================================================
# Moon — متغيرات البيئة المرجعية (Example Environment Variables)
# انسخ هذا الملف إلى .env ولا ترفعه أبدًا إلى git (محمي عبر .gitignore).
# ==============================================================================

# --- بيئة التشغيل ---
ENVIRONMENT=development
LOG_LEVEL=info
APP_SECRET_KEY=change-me-in-production

# --- Cloudflare (apps/api, apps/web) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- قاعدة البيانات العلائقية ---
POSTGRES_USER=moon
POSTGRES_PASSWORD=change-me
POSTGRES_DB=moon
DATABASE_URL=postgresql://moon:change-me@localhost:5432/moon

# --- التخزين المؤقت / الطابور ---
REDIS_URL=redis://localhost:6379/0

# --- قاعدة بيانات الرسم البياني ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# --- تخزين الكائنات (S3-compatible / R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=moon-evidence

# --- مزودي الذكاء الاصطناعي (ai/llm) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- موصلات المصادر (connectors/) — أمثلة، لا تُملأ إلا عند الحاجة ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TWITTER_BEARER_TOKEN=
SHODAN_API_KEY=
HAVEIBEENPWNED_API_KEY=
GOOGLE_API_KEY=

# --- المراقبة (observability/) ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- الأمان (security/secrets) ---
SECRETS_BACKEND=env
JWT_SIGNING_KEY=change-me-too
