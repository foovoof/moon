[importlinter]
root_packages =
    core
    normalizers
    domain
    models
    utils
    platform
    collectors
    analyzers
    graph
    knowledge
    intelligence
    agents
    tools
    processors
    connectors
    workflows
    contracts
    capabilities
    security
    policy_engine
    observability
    apps
    config

# ------------------------------------------------------------------
# طبقة النواة المشتركة لا يجوز أن تعتمد على أي طبقة أعلى منها.
# ------------------------------------------------------------------
[importlinter:contract:core-independence]
name = core و normalizers و domain و models و utils لا تعتمد على طبقات أعلى
type = forbidden
source_modules =
    core
    normalizers
    domain
    models
    utils
forbidden_modules =
    platform
    collectors
    analyzers
    graph
    knowledge
    intelligence
    agents
    tools
    processors
    connectors
    workflows
    apps
    security
    policy_engine

# ------------------------------------------------------------------
# طبقة المنصة (platform) لا تعتمد على طبقات الأعمال العالية.
# ------------------------------------------------------------------
[importlinter:contract:platform-independence]
name = platform لا تعتمد على intelligence/agents/apps
type = forbidden
source_modules =
    platform
forbidden_modules =
    intelligence
    agents
    tools
    processors
    connectors
    workflows
    apps

# ------------------------------------------------------------------
# apps هي أعلى طبقة: لا يجوز لأي طبقة أخرى الاعتماد عليها.
# ------------------------------------------------------------------
[importlinter:contract:apps-is-top-layer]
name = لا شيء يعتمد على apps إلا apps نفسها
type = forbidden
source_modules =
    core
    normalizers
    domain
    models
    utils
    platform
    collectors
    analyzers
    graph
    knowledge
    intelligence
    agents
    tools
    processors
    connectors
    workflows
    contracts
    capabilities
    security
    policy_engine
    observability
    config
forbidden_modules =
    apps

# ------------------------------------------------------------------
# طبقة الجمع/التحليل/المعرفة لا تعتمد على طبقة الوكلاء والتطبيقات.
# ------------------------------------------------------------------
[importlinter:contract:collection-analysis-independence]
name = collectors/analyzers/graph/knowledge لا تعتمد على agents/apps
type = forbidden
source_modules =
    collectors
    analyzers
    graph
    knowledge
forbidden_modules =
    agents
    apps
    workflows
