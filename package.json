{
  "name": "moon",
  "version": "0.1.0",
  "description": "Moon — منصة الاستخبارات والتحقيقات الرقمية (OSINT / Intelligence & Investigation Platform). واجهة الحافة (apps/api, apps/web) مبنية بـ Hono على Cloudflare Pages/Workers.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl -sf http://localhost:3000 > /dev/null && echo OK",
    "git:status": "git status",
    "git:log": "git log --oneline"
  },
  "dependencies": {
    "hono": "^4.12.30"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.11.1",
    "@hono/vite-dev-server": "^0.26.1",
    "vite": "^8.1.4",
    "wrangler": "^4.111.0"
  }
}